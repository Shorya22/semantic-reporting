GROQ_API_KEY=your_groq_api_key_here

# ==============================================================================
# LLM defaults — fall-through values when per-agent slots are blank.
# ==============================================================================
# Provider: "groq" (Groq Cloud) or "ollama" (local).
LLM_PROVIDER=groq

# Default model used when the frontend does not override it AND no per-agent
# override is set below.
#
# Groq Cloud options:
#   Fast / cheap : llama-3.1-8b-instant, gemma2-9b-it, groq/compound-mini
#   Balanced     : llama-3.3-70b-versatile (default), qwen/qwen3-32b, meta-llama/llama-4-scout-17b-16e-instruct
#   Heavy        : openai/gpt-oss-120b, openai/gpt-oss-20b, groq/compound, mixtral-8x7b-32768
# Ollama options:
#   llama3.2, llama3.1, mistral, codellama, phi3, qwen2.5-coder
DEFAULT_MODEL=llama-3.3-70b-versatile

# Ollama base URL (only used when LLM_PROVIDER=ollama or per-agent provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Token / iteration safety nets (override per-agent below if needed)
AGENT_MAX_TOKENS=2048
AGENT_MAX_ITERATIONS=2

# ==============================================================================
# PER-AGENT LLM CONFIG (multi-agent system)
# ------------------------------------------------------------------------------
# Each agent role is configured INDEPENDENTLY here. Pattern:
#   MODEL_<AGENT>      = model id  (Groq or Ollama)
#   PROVIDER_<AGENT>   = "groq" | "ollama"
#   MAX_TOKENS_<AGENT> = integer
#   TEMP_<AGENT>       = 0.0–1.0
#
# All four are optional — leave blank to fall through to the global defaults
# above. Per-request overrides from the frontend (model + provider on
# QueryRequest) take precedence over both per-agent and global defaults.
# ==============================================================================

# --- Intent Classifier --------------------------------------------------------
# Tiny + fast. Classifies user intent ({chart? dashboard? report? simple_qa?})
# in a single short call so the orchestrator can route correctly.
MODEL_INTENT_CLASSIFIER=llama-3.1-8b-instant
PROVIDER_INTENT_CLASSIFIER=groq
MAX_TOKENS_INTENT_CLASSIFIER=400
TEMP_INTENT_CLASSIFIER=0

# --- Planner ------------------------------------------------------------------
# Decomposes the question into an AnalysisPlan: N parallel SQL queries, N
# visuals, and a layout spec. Needs reasoning headroom.
MODEL_PLANNER=llama-3.3-70b-versatile
PROVIDER_PLANNER=groq
MAX_TOKENS_PLANNER=2048
TEMP_PLANNER=0

# --- Schema Agent -------------------------------------------------------------
# Mostly deterministic (caches DDL + cardinality). LLM only used to summarise
# huge schemas for downstream agents when needed.
MODEL_SCHEMA=llama-3.1-8b-instant
PROVIDER_SCHEMA=groq
MAX_TOKENS_SCHEMA=1024
TEMP_SCHEMA=0

# --- SQL Agent (per-query workers) -------------------------------------------
# Writes & runs SQL. Tool-use capable model required.
MODEL_SQL_AGENT=llama-3.3-70b-versatile
PROVIDER_SQL_AGENT=groq
MAX_TOKENS_SQL_AGENT=1024
TEMP_SQL_AGENT=0

# --- Viz Designer -------------------------------------------------------------
# Picks chart type from data shape (numeric vs categorical, cardinality, etc.).
# Mostly rule-based; LLM only resolves ambiguous cases.
MODEL_VIZ_DESIGNER=llama-3.1-8b-instant
PROVIDER_VIZ_DESIGNER=groq
MAX_TOKENS_VIZ_DESIGNER=800
TEMP_VIZ_DESIGNER=0

# --- Insight Agent ------------------------------------------------------------
# Writes the executive summary, key findings, anomalies, recommendations.
# Slight temperature (~0.3) gives nicer prose without hallucinating numbers.
MODEL_INSIGHT_AGENT=llama-3.3-70b-versatile
PROVIDER_INSIGHT_AGENT=groq
MAX_TOKENS_INSIGHT_AGENT=1500
TEMP_INSIGHT_AGENT=0.3

# --- Critic -------------------------------------------------------------------
# Quality gate. Validates the answer addresses the question, no obvious gaps.
MODEL_CRITIC=llama-3.1-8b-instant
PROVIDER_CRITIC=groq
MAX_TOKENS_CRITIC=400
TEMP_CRITIC=0

# ==============================================================================
# Cache backend
# ==============================================================================
# redis     — real Redis at REDIS_URL. Use in production / staging.
#             Falls back to in-memory if the daemon is unreachable.
# fakeredis — pure-Python in-process Redis. Zero setup, no Docker, no daemon.
#             Recommended for development and tests.
# memory    — skip Redis entirely; in-process TTL cache only.
CACHE_BACKEND=fakeredis
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Application metadata DB
# ==============================================================================
# Default = local SQLite (zero-ops). Switch to Postgres in prod:
#   APP_DB_URL=postgresql+psycopg2://user:pass@host:5432/datalens
# APP_DB_URL=sqlite:///./data/app.db

# ==============================================================================
# Crypto
# ==============================================================================
# Fernet key for encrypting Postgres passwords at rest in the metadata DB.
# Leave blank in dev — a key is auto-generated to backend/data/.secret_key.
# REQUIRED in production: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_SECRET_KEY=
