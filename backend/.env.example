GROQ_API_KEY=your_groq_api_key_here

# Groq model used when the frontend does not override it.
# Fast options  : llama-3.1-8b-instant, gemma2-9b-it
# Balanced      : llama-3.3-70b-versatile (default)
# Most capable  : llama-3.3-70b-versatile, mixtral-8x7b-32768
DEFAULT_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------------------------
# Cache backend
# ------------------------------------------------------------------------------
# redis     — real Redis at REDIS_URL. Use in production / staging.
#             Falls back to in-memory if the daemon is unreachable.
# fakeredis — pure-Python in-process Redis. Zero setup, no Docker, no daemon.
#             Recommended for development and tests.
# memory    — skip Redis entirely; in-process TTL cache only.
CACHE_BACKEND=fakeredis
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Application metadata DB
# ------------------------------------------------------------------------------
# Default = local SQLite (zero-ops). Switch to Postgres in prod:
#   APP_DB_URL=postgresql+psycopg2://user:pass@host:5432/datalens
# APP_DB_URL=sqlite:///./data/app.db

# ------------------------------------------------------------------------------
# Crypto
# ------------------------------------------------------------------------------
# Fernet key for encrypting Postgres passwords at rest in the metadata DB.
# Leave blank in dev — a key is auto-generated to backend/data/.secret_key.
# REQUIRED in production: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_SECRET_KEY=
